{
  "name": "agentbank-subgraph",
  "version": "1.0.0",
  "description": "The Graph subgraph for AgentBank protocol on Mantle",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "graph deploy --node https://api.thegraph.com/deploy/ agentbank/agentbank-mantle",
    "deploy:studio": "graph deploy --studio agentbank-mantle",
    "create-local": "graph create --node http://localhost:8020/ agentbank/agentbank-mantle",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 agentbank/agentbank-mantle"
  },
  "dependencies": {
    "@graphprotocol/graph-ts": "^0.31.0"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.62.0"
  }
}
