{
  "name": "agentbank",
  "version": "2.0.0",
  "description": "Multi-agent autonomous treasury on Mantle — five AI agents with Byreal Skills CLI, ERC-8004, analyst marketplace, and verifiable LLM reasoning",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/",
    "test:integration": "hardhat test test/integration/",
    "test:invariants": "hardhat test test/invariants/",
    "test:fuzz": "hardhat test test/fuzz/",
    "test:fork": "hardhat test test/fork/ --network hardhat",
    "deploy:testnet": "hardhat run scripts/deploy_v2_testnet.js --network mantle_sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy_v2_mainnet.js --network mantle",
    "seed": "hardhat run scripts/seed_initial_state.js",
    "verify": "hardhat run scripts/verify_all.js",
    "verify:reasoning": "hardhat run scripts/verify_reasoning.js",
    "migrate": "hardhat run scripts/migrate_v1_to_v2.js"
  },
  "keywords": [
    "mantle",
    "defi",
    "ai-agents",
    "erc4626",
    "erc8004",
    "autonomous-treasury",
    "byreal-skills",
    "multi-agent-economy"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@account-abstraction/contracts": "^0.8.0",
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.168",
    "@layerzerolabs/lz-evm-protocol-v2": "^3.0.168",
    "@layerzerolabs/oapp-evm": "^0.4.1",
    "@layerzerolabs/oft-evm": "^4.0.1",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.4.0"
  }
}
